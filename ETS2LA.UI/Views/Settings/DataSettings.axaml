<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             x:Class="ETS2LA.UI.Views.Settings.DataSettingsPage"
             x:DataType="views:DataSettingsPage">
    <StackPanel>
        <Grid ColumnDefinitions="500,*">
        <StackPanel Grid.Column="0" Spacing="20" Margin="20">
            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Data Fidelity" />
                    <TextBlock Text="Adjust the level of detail of the game data we use. Higher values use more RAM, but include more information. All levels drive the same." FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding DataFidelityOptions}" 
                        SelectedIndex="{Binding SelectedDataFidelityOption}" 
                        SelectionChanged="OnDataFidelityChanged">
                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="70" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
                <StackPanel Spacing="3" IsVisible="{Binding ShowRamWarning}">
                    <TextBlock Text="You cannot use some data fidelity options due to insufficient RAM. High requires 16GB, Extreme requires 20GB." FontSize="12" Classes="Warning" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowLowInfo}">
                    <TextBlock Text="This setting only loads roads and intersections visible on the in game map. It discards all other information." FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowMediumInfo}">
                    <TextBlock Text="This setting drops redundant information while maintaining most detail objects (such as signs). Doesn't include any roads / intersections not shown in the in game map." FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowHighInfo}">
                    <TextBlock Text="This setting drops redundant information while maintaining most detail objects (such as signs). Includes all hidden and AI only roads." FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowExtremeInfo}">
                    <TextBlock Text="This setting includes all available data, most of which is redundant." FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="3" IsVisible="{Binding ShowExtremeWarning}">
                    <TextBlock Text="Warning: Extreme uses significant amounts of RAM, expect over 10GB of usage." FontSize="12" Classes="Warning" />
                </StackPanel>
            </StackPanel>

            <Separator />

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Curve Quality" />
                    <TextBlock Text="Adjust the quality of the curves used for path planning and visualization. By default this matches the game." FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding CurveQualityOptions}" 
                        SelectedIndex="{Binding SelectedCurveQualityOption}" 
                        SelectionChanged="OnCurveQualityChanged">
                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="115" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>
        </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>