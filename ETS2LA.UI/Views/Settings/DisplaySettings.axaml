<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
             x:Class="ETS2LA.UI.Views.Settings.DisplaySettings"
             x:DataType="views:DisplaySettings">
    <StackPanel>
        <Grid ColumnDefinitions="450,*">
        <StackPanel Grid.Column="0" Spacing="24" Margin="20">

            <StackPanel Spacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Display Units" />
                    <TextBlock Text="Which units should be used for displaying values?" FontSize="12" Classes="Description" />
                </StackPanel>
                <TabStrip ItemsSource="{Binding DisplayUnitOptions}" 
                        SelectedIndex="{Binding SelectedDisplayUnitOption}" 
                        SelectionChanged="OnDisplayUnitChanged">
                    <TabStrip.ItemTemplate>
                        <DataTemplate x:DataType="views:TabStripItemHandler">
                            <Border Width="80" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Header}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </TabStrip.ItemTemplate>
                </TabStrip>
            </StackPanel>

            <Separator />

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Limit Overlay Framerate" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding LimitOverlayFramerate}" Classes="primary-toggle" />
                </Grid>
                <TextBlock Text="In most situations, over half of ETS2LA's CPU use will be for the overlay. You can lower it's framerate to reduce CPU and GPU usage." FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Max Overlay Framerate" />
                    <TextBlock Text="{Binding ElementName=MaxFramerateSlider, Path=Value, StringFormat='{}{0:0} FPS'}" />
                </StackPanel>
                <Slider Name="MaxFramerateSlider" Minimum="1" Maximum="120" Value="{Binding MaxOverlayFramerate}" />
            </StackPanel>

            <Separator />

            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Render AR Elements" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding RenderAR}" Classes="primary-toggle" />
                </Grid>
                <TextBlock Text="We can render elements in the game world using our overlay. This will use additional CPU and GPU resources." FontSize="12" Classes="Description" />
            </StackPanel>

            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Max AR Rendering Distance" />
                    <TextBlock Text="{Binding ARDistanceDisplay}" />
                </StackPanel>
                <Slider Name="MaxARDistanceSlider" Minimum="50" Maximum="300" Value="{Binding MaxARDistance}" />
            </StackPanel>

        </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>